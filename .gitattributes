# Normalize all text files to LF in the repo; checkout as-is on all platforms.
# This ensures file sizes are consistent between local Windows and CI environments,
# which matters for the Index.md size summary generated by tools/Update-Index.ps1.
* text=auto eol=lf
*.ps1 text eol=lf
*.psm1 text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Binaries -- no line-ending conversion
*.sig binary
*.png binary
*.ico binary
